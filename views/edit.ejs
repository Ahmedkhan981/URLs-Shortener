<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account Settings - Analytics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --background: 255 255 255;
            --foreground: 0 0 0;
            --card: 255 255 255;
            --card-foreground: 0 0 0;
            --border: 229 231 235;
            --muted: 245 245 245;
            --muted-foreground: 115 115 115;
            --accent: 0 0 0;
            --accent-foreground: 255 255 255;
            --radius: 0.75rem;
            --font-sans: 'Inter', sans-serif;
        }

        [data-theme="dark"] {
            --background: 0 0 0;
            --foreground: 255 255 255;
            --card: 10 10 10;
            --card-foreground: 255 255 255;
            --border: 39 39 42;
            --muted: 18 18 18;
            --muted-foreground: 161 161 170;
            --accent: 255 255 255;
            --accent-foreground: 0 0 0;
        }

        body {
            font-family: var(--font-sans);
            background: rgb(var(--background));
            color: rgb(var(--foreground));
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* GRID BACKGROUND */
        body::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: -1;
            background-image: radial-gradient(circle at 2px 2px, rgb(var(--foreground) / 0.07) 1px, transparent 0);
            background-size: 24px 24px;
        }

        .layout {
            display: grid;
            grid-template-columns: 240px 1fr;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            background: rgb(var(--card));
            border-right: 1px solid rgb(var(--border));
            padding: 2rem 1rem;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .logo {
            font-weight: 800;
            font-size: 1.25rem;
            text-decoration: none;
            color: rgb(var(--foreground));
            letter-spacing: -0.03em;
            padding-left: 0.75rem;
        }

        .nav-group { display: flex; flex-direction: column; gap: 0.35rem; }
        .nav-label { font-size: 0.7rem; font-weight: 800; color: rgb(var(--muted-foreground)); padding: 0 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }

        .nav-item {
            padding: 0.65rem 0.85rem;
            border-radius: 0.6rem;
            color: rgb(var(--muted-foreground));
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
            background: transparent;
            border: none;
            text-align: left;
            cursor: pointer;
            width: 100%;
        }

        .nav-item:hover, .nav-item.active {
            background: rgb(var(--muted));
            color: rgb(var(--foreground));
        }

        /* Main Content */
        .main { width: 100%; }

        .header {
            height: 64px;
            border-bottom: 1px solid rgb(var(--border));
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            background: rgb(var(--background) / 0.8);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 40;
        }

        .content {
            padding: 2.5rem 2rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .page-title {
            font-size: 2.25rem;
            font-weight: 800;
            margin-bottom: 2rem;
            letter-spacing: -0.04em;
        }

        /* Alerts */
        .alert {
            padding: 1rem;
            border-radius: 0.75rem;
            margin-bottom: 2rem;
            font-size: 0.875rem;
            font-weight: 600;
            text-align: center;
            border: 1px solid transparent;
        }
        .alert-error { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.2); color: #ef4444; }
        .alert-success { background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.2); color: #22c55e; }

        /* Sections */
        .settings-section { display: none; }
        .settings-section.active { display: block; animation: fadeIn 0.3s ease; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

        /* Cards */
        .card {
            background: rgb(var(--card));
            border: 1px solid rgb(var(--border));
            border-radius: 1.25rem;
            overflow: hidden;
            margin-bottom: 2rem;
        }

        .card-header { padding: 1.75rem; border-bottom: 1px solid rgb(var(--border)); }
        .card-title { font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em; }
        .card-description { font-size: 0.875rem; color: rgb(var(--muted-foreground)); margin-top: 0.4rem; }
        .card-content { padding: 1.75rem; }

        /* Forms */
        .form-group { margin-bottom: 1.5rem; }
        .form-label { display: block; font-size: 0.85rem; font-weight: 700; margin-bottom: 0.6rem; color: rgb(var(--foreground)); }
        .form-input {
            width: 100%;
            padding: 0.75rem;
            border-radius: 0.75rem;
            border: 1px solid rgb(var(--border));
            background: rgb(var(--muted));
            color: rgb(var(--foreground));
            font-family: inherit;
            font-size: 0.9rem;
        }
        .form-input:focus { outline: none; border-color: rgb(var(--foreground)); background: rgb(var(--card)); }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.6rem;
            padding: 0.6rem 1.25rem;
            font-size: 0.875rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            border: 1px solid rgb(var(--border));
        }

        .btn-primary {
            background: rgb(var(--accent));
            color: rgb(var(--accent-foreground));
            border: none;
        }

        .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

        .btn-ghost {
            background: transparent;
            color: rgb(var(--muted-foreground));
            border: none;
        }

        .btn-ghost:hover {
            background: rgb(var(--muted));
            color: rgb(var(--foreground));
        }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1rem;
            font-size: 0.85rem;
            font-weight: 600;
            color: rgb(var(--muted-foreground));
            text-decoration: none;
            transition: color 0.2s;
        }
        .back-btn:hover { color: rgb(var(--foreground)); }

        @media (max-width: 768px) {
            .layout { grid-template-columns: 1fr; }
            .sidebar { border-right: none; border-bottom: 1px solid rgb(var(--border)); padding-bottom: 1rem; }
        }
        /* Ensure the parent doesn't allow the sidebar to push past the viewport */
.layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    height: 100vh; /* Lock the total height to the screen */
    overflow: hidden; /* Prevent body scroll */
}

.sidebar {
    border-right: 1px solid rgb(var(--border));
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background: rgb(var(--background));
    
    /* The Fix: Lock it to the screen */
    height: 100vh;
    position: sticky;
    top: 0;
    overflow-y: auto; /* If the nav items are too many, only the sidebar scrolls */
}

.main {
    height: 100vh;
    overflow-y: auto; /* This allows the content to scroll while the sidebar stays put */
    background: transparent;
}
    </style>
</head>
<body>

    <div class="layout">
        <aside class="sidebar">
            <a class="logo" href="/">ANALYTICS</a>
            
            <div class="nav-group">
                <span class="nav-label">Settings</span>
                <a class="nav-item" href="/profile" >
                    Go Back
                </a>
                <button class="nav-item active" id="btn-profile" onclick="showSection('profile-info', this)">
                    Profile Information
                </button>
                <button class="nav-item" id="btn-security" onclick="showSection('security-settings', this)">
                    Security & Password
                </button>
            </div>

            <nav class="nav-group" style="margin-top: auto;">
                <a href="/logout" class="nav-item" style="color: #ef4444;">Logout</a>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <h2 id="breadcrumb" style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: rgb(var(--muted-foreground));">Account / Profile</h2>
                
                <button class="btn btn-ghost" onclick="toggleTheme()" style="padding: 8px; border: 1px solid rgb(var(--border));">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                </button>
            </header>

            <div class="content">
                <a href="/profile" class="back-btn">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
                    Back to Dashboard
                </a>

                <h1 class="page-title">Settings</h1>

                <% if (locals.messages) { %>
                    <% if (messages.error && messages.error.length > 0) { %>
                        <div class="alert alert-error"><%= messages.error %></div>
                    <% } %>
                    <% if (messages.message && messages.message.length > 0) { %>
                        <div class="alert alert-success"><%= messages.message %></div>
                    <% } %>
                <% } %>

                <div class="section-container">
                    <section id="profile-info" class="settings-section active">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Profile Information</h3>
                                <p class="card-description">Update your display name and public identity.</p>
                            </div>
                            <div class="card-content">
                                <form method="POST" action="/profile/edit" enctype="multipart/form-data">
                                    <div class="form-group">
                                        <label class="form-label">Profile Name</label>
                                        <input type="text" name="username" class="form-input" value="<%= locals.username || '' %>" required>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Save Changes</button>
                                </form>
                            </div>
                        </div>
                    </section>

                    <section id="security-settings" class="settings-section">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Security Settings</h3>
                                <p class="card-description">Keep your account safe by updating your password regularly.</p>
                            </div>
                            <div class="card-content">
                                <form method="POST" action="/profile/edit">
                                                    <% if (noneSelected) { %>
                                    <div class="form-group">
                                        <label class="form-label">Current Password</label>
                                        <input type="password" name="currentPassword" class="form-input" placeholder="••••••••" required>
                                    </div>
                                                    <% } %>
                                    <div class="form-group">
                                        <label class="form-label">New Password</label>
                                        <input type="password" name="newPassword" class="form-input" placeholder="••••••••" required>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Confirm New Password</label>
                                        <input type="password" name="confirmPassword" class="form-input" placeholder="••••••••" required>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Update Password</button>
                                </form>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const savedSection = localStorage.getItem('activeSection') || 'profile-info';
            const btn = document.getElementById(savedSection === 'profile-info' ? 'btn-profile' : 'btn-security');
            showSection(savedSection, btn, false);
        });

        function showSection(sectionId, element, shouldSave = true) {
            document.querySelectorAll('.settings-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));

            const target = document.getElementById(sectionId);
            if (target) {
                target.classList.add('active');
                element.classList.add('active');
                
                const bread = document.getElementById('breadcrumb');
                bread.innerText = sectionId === 'profile-info' ? 'Account / Profile' : 'Account / Security';

                if (shouldSave) localStorage.setItem('activeSection', sectionId);
            }
        }

        function toggleTheme() {
            const html = document.documentElement;
            const theme = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);
        }
        
        if(localStorage.getItem('theme')) document.documentElement.setAttribute('data-theme', localStorage.getItem('theme'));

        // Auto-hide alerts
        setTimeout(() => {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(a => {
                a.style.transition = 'opacity 0.5s ease';
                a.style.opacity = '0';
                setTimeout(() => a.remove(), 500);
            });
        }, 5000);
    </script>
</body>
</html>