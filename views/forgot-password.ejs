<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - Analytic</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --background: 255 255 255;
            --foreground: 9 9 11;
            --card: 255 255 255;
            --card-foreground: 9 9 11;
            --border: 228 228 231;
            --muted: 244 244 245;
            --muted-foreground: 113 113 122;
            --accent: 9 9 11;
            --accent-foreground: 255 255 255;
            --font-sans: "Inter", sans-serif;
        }

        [data-theme="dark"] {
            --background: 0 0 0;
            --foreground: 250 250 250;
            --card: 10 10 10;
            --card-foreground: 250 250 250;
            --border: 39 39 42;
            --muted: 18 18 18;
            --muted-foreground: 161 161 170;
            --accent: 250 250 250;
            --accent-foreground: 0 0 0;
        }

        body {
            font-family: var(--font-sans);
            background-color: rgb(var(--background));
            color: rgb(var(--foreground));
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            -webkit-font-smoothing: antialiased;
        }

        /* GRID BACKGROUND */
        .grid-background {
            position: fixed;
            inset: 0;
            z-index: -1;
            background-image: radial-gradient(circle at 2px 2px, rgb(var(--foreground) / 0.07) 1px, transparent 0);
            background-size: 24px 24px;
        }

        .header-container {
            height: 64px;
            padding: 0 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgb(var(--border));
            background: rgb(var(--background) / 0.8);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .logo { font-size: 0.9rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; text-decoration: none; color: inherit; }

        .theme-toggle {
            width: 36px; height: 36px;
            background: transparent;
            border: 1px solid rgb(var(--border));
            border-radius: 0.6rem;
            cursor: pointer;
            color: rgb(var(--foreground));
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s;
        }
        .theme-toggle:hover { background: rgb(var(--muted)); }

        .main-container {
            flex: 1; display: flex; align-items: center; justify-content: center;
            padding: 2rem 1.5rem;
        }

        .content { max-width: 400px; width: 100%; }

        .verify-card {
            background: rgb(var(--card));
            padding: 2.5rem;
            border-radius: 1.25rem;
            border: 1px solid rgb(var(--border));
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            color: rgb(var(--muted-foreground));
            text-decoration: none;
            margin-bottom: 1.5rem;
            transition: color 0.2s;
        }
        .back-link:hover { color: rgb(var(--foreground)); }

        .form-header { margin-bottom: 2rem; }
        .form-title { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; letter-spacing: -0.04em; }
        .form-subtitle { color: rgb(var(--muted-foreground)); font-size: 0.95rem; line-height: 1.5; }

        .form-input-field {
            width: 100%; padding: 0.75rem 1rem;
            background: rgb(var(--muted));
            color: rgb(var(--foreground));
            border: 1px solid rgb(var(--border));
            border-radius: 0.75rem;
            font-size: 0.95rem; margin-bottom: 1.25rem;
            font-family: inherit;
            transition: all 0.2s ease;
        }
        .form-input-field:focus { outline: none; border-color: rgb(var(--foreground)); background: transparent; }

        .form-button {
            width: 100%; padding: 0.8rem; 
            background: rgb(var(--accent)); 
            color: rgb(var(--accent-foreground));
            font-weight: 700; border: none; border-radius: 0.75rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 0.5rem;
            font-size: 0.95rem;
            transition: opacity 0.2s, transform 0.1s;
        }
        .form-button:hover { opacity: 0.9; }
        .form-button:active { transform: translateY(1px); }

        /* Alerts */
        .alert {
            padding: 0.85rem; border-radius: 0.75rem; margin-bottom: 1.5rem;
            font-size: 0.85rem; font-weight: 600; text-align: center;
            border: 1px solid transparent; animation: fadeIn 0.3s ease;
        }
        .alert-error { background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2); color: #f87171; }
        .alert-success { background: rgba(34, 197, 94, 0.1); border-color: rgba(34, 197, 94, 0.2); color: #4ade80; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }

        .loading {
            display: none; width: 1.2rem; height: 1.2rem;
            border: 2px solid rgba(var(--accent-foreground), 0.3); border-radius: 50%;
            border-top-color: rgb(var(--accent-foreground)); animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="grid-background"></div>
    
    <header class="header-container">
        <a href="/" class="logo">Analytic</a>
        <button class="theme-toggle" onclick="toggleTheme()">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
        </button>
    </header>

    <main class="main-container">
        <div class="content">
            <div class="verify-card">
                <a href="/login" class="back-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
                    Back to login
                </a>

                <% if (locals.error) { %>
                    <div class="alert alert-error"><%= error %></div>
                <% } %>
                <% if (locals.message) { %>
                    <div class="alert alert-success"><%= message %></div>
                <% } %>

                <div class="form-header">
                    <h1 class="form-title">Forgot password?</h1>
                    <p class="form-subtitle">No worries, we'll send you a recovery link to reset your password.</p>
                </div>

                <form action="/auth/forgot-password" method="POST" id="requestForm">
                    <input type="email" name="email" class="form-input-field" placeholder="name@company.com" required autofocus />
                    <button type="submit" class="form-button" id="submitBtn">
                        <span id="btnText">Send reset link</span>
                        <div id="btnLoading" class="loading"></div>
                    </button>
                </form>
            </div>
        </div>
    </main>

    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const target = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
            html.setAttribute("data-theme", target);
            localStorage.setItem("theme", target);
        }

        // Apply theme on load
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme) document.documentElement.setAttribute("data-theme", savedTheme);

        const form = document.getElementById("requestForm");
        form.addEventListener("submit", () => {
            const btn = document.getElementById("submitBtn");
            btn.style.opacity = "0.7";
            btn.style.pointerEvents = "none";
            document.getElementById("btnText").style.display = "none";
            document.getElementById("btnLoading").style.display = "inline-block";
        });
    </script>
</body>
</html>