<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Analytic - URL Shortener</title>
    <meta name="description" content="Concise and trackable links" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --background: 255 255 255;
        --foreground: 0 0 0;
        --card: 255 255 255;
        --card-foreground: 0 0 0;
        --border: 229 231 235;
        --muted: 245 245 245;
        --muted-foreground: 115 115 115;
        --accent: 0 0 0;
        --accent-foreground: 255 255 255;
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      }

      [data-theme="dark"] {
        --background: 0 0 0;
        --foreground: 255 255 255;
        --card: 0 0 0;
        --card-foreground: 255 255 255;
        --border: 39 39 42;
        --muted: 18 18 18;
        --muted-foreground: 161 161 170;
        --accent: 255 255 255;
        --accent-foreground: 0 0 0;
      }

      body {
        font-family: var(--font-sans);
        background-color: rgb(var(--background));
        color: rgb(var(--foreground));
        line-height: 1.5;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
      }

      /* Refined Grid Background from First Theme */
      .grid-background {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
        background-image: radial-gradient(circle at 2px 2px, rgb(var(--foreground) / 0.07) 1px, transparent 0);
        background-size: 24px 24px;
      }

      /* Navbar */
      .navbar {
        border-bottom: 1px solid rgb(var(--border));
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgb(var(--card) / 0.8);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .logo {
        font-weight: 800;
        font-size: 1.5rem;
        text-decoration: none;
        color: rgb(var(--foreground));
        letter-spacing: -0.04em;
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      /* User Profile Section */
      .user-pill {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.4rem 1rem 0.4rem 0.4rem;
        background: rgb(var(--muted));
        border: 1px solid rgb(var(--border));
        border-radius: 2rem;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .user-pill:hover {
        background: rgb(var(--foreground) / 0.05);
        transform: translateY(-1px);
      }

      .avatar {
        width: auto;
        height: 2rem;
        border-radius: 50%;
        color: rgb(var(--background));
        display: flex;
        gap:0.5rem;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: 800;
      }
      .avatar-letter {
        width:2rem;
        height: 2rem;
        border-radius: 50%;
        color: rgb(var(--background));
        background: rgb(var(--foreground));
        display: flex;
        gap:0.5rem;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: 800;
      }

      .user-name {
        font-size: 0.875rem;
        font-weight: 700;
        color: rgb(var(--foreground));
      }

      /* Premium Theme Toggle (Re-styled for Navbar) */
      .theme-toggle {
        width: 2.5rem;
        height: 2.5rem;
        background: rgb(var(--card));
        border: 1px solid rgb(var(--border));
        border-radius: 0.75rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
      }

      .theme-toggle:hover {
        background: rgb(var(--muted));
        transform: translateY(-2px);
      }

      .theme-toggle svg {
        width: 1.25rem;
        height: 1.25rem;
        color: rgb(var(--foreground));
      }

      /* Main Content Card */
      .container {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem;
      }

      .card {
        width: 100%;
        max-width: 480px;
        background: rgb(var(--card));
        padding: 2.5rem;
        border-radius: 1.25rem;
        border: 1px solid rgb(var(--border));
        box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(8px);
      }

      .card-header {
        text-align: center;
        margin-bottom: 2rem;
      }

      .card-title {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
      }

      .card-description {
        color: rgb(var(--muted-foreground));
        font-size: 0.95rem;
      }

      /* Form Elements */
      .form-group {
        margin-bottom: 1.5rem;
      }

      .form-label {
        display: block;
        margin-bottom: 0.5rem;
        color: rgb(var(--foreground));
        font-weight: 600;
        font-size: 0.8125rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .form-input {
        width: 100%;
        padding: 0.875rem 1rem;
        background: rgb(var(--muted));
        color: rgb(var(--foreground));
        border: 1px solid rgb(var(--border));
        border-radius: 0.75rem;
        font-size: 0.95rem;
        font-family: inherit;
        transition: all 0.2s ease;
      }

      .form-input:focus {
        outline: none;
        background: rgb(var(--card));
        border-color: rgb(var(--foreground));
        box-shadow: 0 0 0 4px rgb(var(--foreground) / 0.05);
      }

      .form-input[readonly] {
        opacity: 0.7;
        cursor: default;
      }

      /* Copy Button Wrapper */
      .copy-wrapper {
        display: flex;
        gap: 0.5rem;
      }

      .btn-copy {
        background: rgb(var(--muted));
        border: 1px solid rgb(var(--border));
        border-radius: 0.75rem;
        padding: 0 1rem;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        color: rgb(var(--foreground));
      }

      .btn-copy:hover {
        background: rgb(var(--foreground));
        color: rgb(var(--background));
      }

      /* Buttons */
      .btn {
        padding: 0.75rem 1.25rem;
        border-radius: 0.75rem;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .btn-primary {
        background: rgb(var(--accent));
        color: rgb(var(--accent-foreground));
        width: 100%;
      }

      .btn-primary:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        box-shadow: 0 8px 20px -4px rgb(var(--accent) / 0.3);
      }

      .btn-outline {
        background: transparent;
        border: 1px solid rgb(var(--border));
        color: rgb(var(--foreground));
        font-size: 0.875rem;
      }

      .btn-outline:hover {
        background: rgb(var(--muted));
      }

      /* Alerts */
      .alert {
        padding: 1rem;
        border-radius: 0.75rem;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        border: 1px solid transparent;
      }

      .alert-success {
        background: rgba(34, 197, 94, 0.1);
        border-color: rgba(34, 197, 94, 0.2);
        color: #22c55e;
      }

      /* Loader */
      .loading-spinner {
        width: 1.25rem;
        height: 1.25rem;
        border: 2px solid rgb(var(--accent-foreground) / 0.3);
        border-radius: 50%;
        border-top-color: rgb(var(--accent-foreground));
        animation: spin 0.8s linear infinite;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }


      @media (max-width: 480px) {
        .navbar { padding: 1rem; }
        .card { 
          padding: 1.5rem; 
          border: none; 
          background: transparent; 
          box-shadow: none; 
        }
      }
      .avatar-img{
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
      }
    </style>
  </head>

  <body>
    <div class="grid-background"></div>

    <header class="navbar">
      <a href="/" class="logo">Analytic</a>
      <div class="nav-right">
        <% if (typeof user !== 'undefined' && user) { %>
        <a href="/profile" class="user-pill">
          <% if (user?.profilePicture) { %>
<div class="avatar">
    <img 
      src="<%= user.profilePicture %>" 
      alt="Profile Picture"
      class="avatar-img"
    />
    <span class="user-name"><%= user.username %></span>
  </div>
  <% } else { %>
    <div class="avatar-letter">

      <%= user?.username?.charAt(0).toUpperCase() || "U" %>
    </div>
    <span class="user-name"><%= user.username %></span>
  <% } %>
        </a>
        <a href="/auth/logout" class="btn btn-outline">Logout</a>
        <% } else { %>
        <a href="/auth/login" class="btn btn-outline">Login</a>
        <% } %>

        <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
        </button>
      </div>
    </header>

    <main class="container">
      <div class="card">
        <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          <%= message %>
        </div>
        <% } %>

        <div class="card-header">
          <h1 class="card-title">Shorten URL</h1>
          <p class="card-description">Create concise, trackable links in seconds.</p>
        </div>

        <form action="/" method="POST" id="shortenerForm">
          <div class="form-group">
            <label class="form-label" for="originalUrl">Target URL</label>
            <input 
              type="url" 
              id="originalUrl" 
              name="url[originalUrl]" 
              class="form-input" 
              placeholder="https://example.com/very-long-link..." 
              required 
            />
          </div>

          <button type="submit" class="btn btn-primary" id="submitButton" style="height: 3rem;">
            <span id="buttonText">Create Link</span>
            <div id="buttonLoading" class="loading-spinner" style="display: none"></div>
          </button>

          <div class="form-group" style="margin-top: 2rem;">
            <label class="form-label">Resulting Short Link</label>
            <div class="copy-wrapper">
              <input 
                type="text" 
                id="shortUrl" 
                class="form-input" 
                readonly 
                value="<%= typeof shortUrl !== 'undefined' && shortUrl ? `${origin}/${shortUrl}` : '' %>"
                placeholder="Short link will appear here..."
              />
              <% if (typeof shortUrl !== 'undefined' && shortUrl) { %>
              <button type="button" class="btn-copy" onclick="copyToClipboard()" title="Copy">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                </svg>
              </button>
              <% } %>
            </div>
          </div>
        </form>
      </div>
    </main>

    <script>
      function toggleTheme() {
        const doc = document.documentElement;
        const currentTheme = doc.getAttribute("data-theme");
        const newTheme = currentTheme === "dark" ? "light" : "dark";
        doc.setAttribute("data-theme", newTheme);
        localStorage.setItem("theme", newTheme);
      }

      (function() {
        const saved = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", saved);
      })();

      document.getElementById("shortenerForm").addEventListener("submit", function() {
        const btn = document.getElementById("submitButton");
        btn.disabled = true;
        document.getElementById("buttonText").style.display = "none";
        document.getElementById("buttonLoading").style.display = "block";
      });

      function copyToClipboard() {
        const input = document.getElementById("shortUrl");
        input.select();
        document.execCommand("copy");
        
        const btn = document.querySelector('.btn-copy');
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<svg width="18" height="18" fill="none" stroke="#22c55e" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>';
        setTimeout(() => btn.innerHTML = originalHtml, 2000);
      }
    </script>
  </body>
</html>