<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Email - Analytic</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --background: 255 255 255;
            --foreground: 0 0 0;
            --card: 255 255 255;
            --card-foreground: 0 0 0;
            --border: 229 231 235;
            --muted: 245 245 245;
            --muted-foreground: 115 115 115;
            --accent: 0 0 0;
            --accent-foreground: 255 255 255;
            --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        [data-theme="dark"] {
            --background: 0 0 0;
            --foreground: 255 255 255;
            --card: 0 0 0;
            --card-foreground: 255 255 255;
            --border: 39 39 42;
            --muted: 18 18 18;
            --muted-foreground: 161 161 170;
            --accent: 255 255 255;
            --accent-foreground: 0 0 0;
        }

        body {
            font-family: var(--font-sans);
            background-color: rgb(var(--background));
            color: rgb(var(--foreground));
            line-height: 1.5;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* Premium Grid Background */
        .grid-background {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: -1;
            background-image: radial-gradient(circle at 2px 2px, rgb(var(--foreground) / 0.07) 1px, transparent 0);
            background-size: 24px 24px;
        }

        /* Navbar */
        .navbar {
            border-bottom: 1px solid rgb(var(--border));
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgb(var(--card) / 0.8);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo { font-weight: 800; font-size: 1.5rem; text-decoration: none; color: rgb(var(--foreground)); letter-spacing: -0.04em; }

        .nav-right { display: flex; align-items: center; gap: 1rem; }

        .user-pill {
            display: flex; align-items: center; gap: 0.75rem; padding: 0.4rem 1rem 0.4rem 0.4rem;
            background: rgb(var(--muted)); border: 1px solid rgb(var(--border)); border-radius: 2rem;
            text-decoration: none; transition: all 0.2s ease;
        }

        .avatar {
            width: 2rem; height: 2rem; border-radius: 50%;
            background: rgb(var(--foreground)); color: rgb(var(--background));
            display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 800;
        }
.theme-toggle {
            width: 2.5rem; height: 2.5rem; background: rgb(var(--card));
            border: 1px solid rgb(var(--border)); border-radius: 0.75rem;
            cursor: pointer; display: flex; align-items: center; justify-content: center; 
            transition: all 0.2s ease;
        }

[data-theme="light"] .theme-toggle svg {
    stroke: #000; 
}
[data-theme="dark"] .theme-toggle svg {
    stroke: #fff;
}

        .container { flex: 1; display: flex; align-items: center; justify-content: center; padding: 2rem 1.5rem; }

        .card {
            width: 100%; max-width: 440px; background: rgb(var(--card)); padding: 2.5rem;
            border-radius: 1.5rem; border: 1px solid rgb(var(--border));
            box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(8px);
        }

        .card-header { text-align: center; margin-bottom: 2rem; }
        .card-title { font-size: 1.75rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.5rem; }
        .card-subtitle { color: rgb(var(--muted-foreground)); font-size: 0.95rem; }
        .email-highlight { color: rgb(var(--foreground)); font-weight: 700; }

        /* Input Styling */
        .code-input {
            width: 100%; padding: 1rem; background: rgb(var(--muted)); color: rgb(var(--foreground));
            border: 2px solid rgb(var(--border)); border-radius: 0.75rem;
            font-size: 1.5rem; font-weight: 800; text-align: center; letter-spacing: 0.5rem;
            font-family: inherit; transition: all 0.2s ease; margin-bottom: 1.5rem;
        }

        .code-input:focus { outline: none; border-color: rgb(var(--foreground)); background: rgb(var(--card)); }

        .btn-primary {
            width: 100%; padding: 0.875rem; background: rgb(var(--accent)); color: rgb(var(--accent-foreground));
            font-weight: 700; font-size: 0.95rem; border: none; border-radius: 0.75rem;
            cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 8px 20px -4px rgb(var(--accent) / 0.3); }
        .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

        .resend-section { margin-top: 1.5rem; text-align: center; font-size: 0.875rem; color: rgb(var(--muted-foreground)); }
        .resend-link { background: none; border: none; color: rgb(var(--foreground)); font-weight: 700; cursor: pointer; text-decoration: underline; text-underline-offset: 4px; }

        /* Alerts */
        .alert { padding: 0.875rem; border-radius: 0.75rem; margin-bottom: 1.25rem; font-size: 0.875rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; border: 1px solid transparent; }
        .alert-error { background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2); color: #ef4444; }
        .alert-success { background: rgba(34, 197, 94, 0.1); border-color: rgba(34, 197, 94, 0.2); color: #22c55e; }

        .loader { width: 1.25rem; height: 1.25rem; border: 2px solid rgb(var(--accent-foreground) / 0.3); border-radius: 50%; border-top-color: rgb(var(--accent-foreground)); animation: spin 0.8s linear infinite; display: none; }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>

<body>
    <div class="grid-background"></div>

    <header class="navbar">
        <a href="/" class="logo">Analytic</a>
        <div class="nav-right">
            <% if (typeof user !== 'undefined' && user) { %>
            <div class="user-pill">
                <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
                <span style="font-size: 0.875rem; font-weight: 700;"><%= user.username %></span>
            </div>
            <% } %>
            <button class="theme-toggle" onclick="toggleTheme()">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                </svg>
            </button>
        </div>
    </header>

    <main class="container">
        <div class="card">
            <% if (locals.error) { %>
            <div class="alert alert-error">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <%= error %>
            </div>
            <% } %>

            <% if (locals.message) { %>
            <div class="alert alert-success">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span><%- message %></span>
            </div>
            <% } %>

            <div class="card-header">
                <h1 class="card-title">Security Check</h1>
                <p class="card-subtitle">
                    Enter the 8-digit code sent to<br>
                    <span class="email-highlight"><%= locals.userEmail || 'your email' %></span>
                </p>
            </div>

            <form action="<%= action %>" method="POST" id="verifyForm">
                <input
                    type="text"
                    name="code"
                    id="verificationCode"
                    class="code-input"
                    placeholder="00000000"
                    maxlength="8"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    required
                />

                <button type="submit" class="btn-primary" id="submitBtn">
                    <span id="btnText">Verify Account</span>
                    <div id="btnLoading" class="loader"></div>
                </button>
            </form>

            <div class="resend-section">
                <span>Didn't receive it?</span>
                <form action="<%= resendRoute %>" method="POST" style="display: inline;">
                    <button type="submit" class="resend-link">Resend Code</button>
                </form>
            </div>
        </div>
    </main>

    <script>
        function toggleTheme() {
            const doc = document.documentElement;
            const target = doc.getAttribute("data-theme") === "dark" ? "light" : "dark";
            doc.setAttribute("data-theme", target);
            localStorage.setItem("theme", target);
        }

        (function () {
            const theme = localStorage.getItem("theme") || "dark";
            document.documentElement.setAttribute("data-theme", theme);
        })();

        const form = document.getElementById("verifyForm");
        const codeInput = document.getElementById("verificationCode");
        const submitBtn = document.getElementById("submitBtn");

        form.addEventListener("submit", () => {
            document.getElementById("btnText").style.display = "none";
            document.getElementById("btnLoading").style.display = "block";
            submitBtn.disabled = true;
        });

        // Numeric only and auto-submit
        codeInput.addEventListener("input", (e) => {
            e.target.value = e.target.value.replace(/[^0-9]/g, "");
            if (e.target.value.length === 8) {
                form.submit();
            }
        });

        window.onload = () => codeInput.focus();
    </script>
</body>
</html>