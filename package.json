{
  "name": "urlshortener",
  "version": "1.0.0",
  "description": "URL Shortener with Bun, Express, and Drizzle",
  "main": "dist/server.js",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "arctic": "^3.7.0",
    "argon2": "^0.44.0",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.2",
    "jsonwebtoken": "^9.0.3",
    "mjml": "^4.18.0",
    "multer": "^2.1.1",
    "mysql2": "^3.16.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.3",
    "request-ip": "^3.3.0",
    "resend": "^6.10.0",
    "winston": "^3.19.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/connect-flash": "^0.0.40",
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-mysql-session": "^3.0.8",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mjml": "^4.7.4",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "^7.0.11",
    "@types/request-ip": "^0.0.41",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "private": true
}
